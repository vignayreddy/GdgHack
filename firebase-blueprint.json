{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data including role and activity tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User's role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in." }
      },
      "required": ["uid", "email", "role"]
    },
    "Streak": {
      "title": "Streak",
      "description": "User activity streak data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID." },
        "currentStreak": { "type": "number", "description": "Current consecutive active days." },
        "lastActive": { "type": "string", "format": "date-time", "description": "Last activity timestamp." },
        "history": { "type": "array", "items": { "type": "string" }, "description": "List of active dates (YYYY-MM-DD)." }
      },
      "required": ["uid", "currentStreak", "lastActive"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications for inactivity or updates.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID." },
        "title": { "type": "string", "description": "Notification title." },
        "message": { "type": "string", "description": "Notification message." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the notification was created." }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    },
    "HelpRequest": {
      "title": "HelpRequest",
      "description": "User help requests for specific categories.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID." },
        "category": { "type": "string", "description": "Request category." },
        "message": { "type": "string", "description": "Request message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the request was created." }
      },
      "required": ["userId", "category", "message", "createdAt"]
    },
    "Mood": {
      "title": "Mood",
      "description": "User mood check-ins.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "User ID." },
        "mood": { "type": "string", "description": "Mood value." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the mood was recorded." }
      },
      "required": ["userId", "mood", "timestamp"]
    },
    "Mentor": {
      "title": "Mentor",
      "description": "Available mentors for the NGO.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Mentor name." },
        "expertise": { "type": "string", "description": "Expertise area." },
        "available": { "type": "boolean", "description": "Availability status." }
      },
      "required": ["name", "expertise", "available"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/streaks/{userId}": {
      "schema": "Streak",
      "description": "User streak tracking documents."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notification documents."
    },
    "/help_requests/{requestId}": {
      "schema": "HelpRequest",
      "description": "User help request documents."
    },
    "/moods/{moodId}": {
      "schema": "Mood",
      "description": "User mood check-in documents."
    },
    "/mentors/{mentorId}": {
      "schema": "Mentor",
      "description": "Mentor documents."
    }
  }
}
